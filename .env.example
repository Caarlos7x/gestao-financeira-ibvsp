VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: URL publicada do Google Apps Script (implantação como app da Web, POST JSON)
# para anexar linhas na planilha sem servidor próprio. Nunca coloque chave de serviço aqui.
VITE_GOOGLE_APPS_SCRIPT_URL=

# Desenvolvimento: com pnpm dev o login é IGNORADO por padrão. Para testar Firebase: VITE_DEV_SKIP_AUTH=false
# VITE_DEV_SKIP_AUTH=false

# Login local SEM Firebase (só pnpm dev): junto com VITE_DEV_SKIP_AUTH=false — usuários/senha em src/config/localTestAuth.ts
# VITE_ENABLE_LOCAL_TEST_LOGIN=true

# Deploy / demo (Vercel): true = sem Firebase, sessão como admin@sistema.test (mock). Público — só demonstração.
# VITE_DEMO_SKIP_AUTH=true

# Usuários de teste (crie no Firebase Authentication; a senha você define no console — veja README):
# - admin@sistema.test     → administrador, organização Igreja Batista - Vila São Pedro
# - operador@sistema.test  → operador financeiro, mesma organização
