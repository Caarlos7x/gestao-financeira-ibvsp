VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: URL publicada do Google Apps Script (implantação como app da Web, POST JSON)
# para anexar linhas na planilha sem servidor próprio. Nunca coloque chave de serviço aqui.
VITE_GOOGLE_APPS_SCRIPT_URL=

# Desenvolvimento: com npm run dev o login é IGNORADO por padrão (acesso direto às telas).
# Para testar Firebase localmente: VITE_DEV_SKIP_AUTH=false
# VITE_DEV_SKIP_AUTH=false

# Usuários de teste (crie no Firebase Authentication com a mesma senha, ex.: Teste@123):
# - admin@sistema.test     → administrador, organização Igreja Batista - Vila São Pedro
# - operador@sistema.test  → operador financeiro, mesma organização
